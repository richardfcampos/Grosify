# === Banco ===
DATABASE_URL=postgresql://user:pass@localhost:5433/grosify

# === Better Auth ===
# Segredo p/ assinar sessões e tokens. Gere com: openssl rand -base64 32
BETTER_AUTH_SECRET=
# URL pública DESTA API — base dos links de reset/verificação no email.
BETTER_AUTH_URL=http://localhost:3010

# === Origens do web (CORS + Better Auth trustedOrigins) ===
WEB_ORIGIN=http://localhost:5174           # lista separada por vírgula em prod
CROSS_SITE_COOKIES=false                    # true quando web e API ficam em domínios diferentes

# === Email (envio com inversão de dependência) ===
# Sem RESEND_API_KEY o envio cai no no-op (loga, não manda) — dev funciona sem credencial.
EMAIL_PROVIDER=resend                       # resend | noop (default: resend se houver chave, senão noop)
RESEND_API_KEY=                             # chave da API do Resend — https://resend.com
EMAIL_FROM=Grosify <no-reply@grosify.app>   # remetente; o domínio precisa estar verificado no Resend
RESEND_WEBHOOK_SECRET=                       # segredo do webhook (Svix) p/ tratar bounce/reclamação. Vazio = aceita sem verificar (dev)

# === Anti-abuso ===
# Turnstile (anti-bô do Cloudflare). Vazio = DESLIGADO (passthrough). Setar quando criar o widget no CF.
# No web, defina também VITE_TURNSTILE_SITE_KEY (apps/web) com a site key correspondente.
TURNSTILE_SECRET=
# Trava de conta (força-bruta) e bloqueio de e-mail descartável + senha-vazada (HIBP) são automáticos,
# sem env. DDoS volumétrico é tratado na borda (regras de rate-limit + WAF no painel Cloudflare).

# === Billing Asaas (sem credencial → rotas /billing respondem 501) ===
# ASAAS_API_KEY=
# ASAAS_WEBHOOK_TOKEN=
# ASAAS_BASE_URL=https://api-sandbox.asaas.com/v3

# === Uploads R2 (opcional; sem isto, fotos caem no blob local) ===
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# === NFC-e — Gemini (embedding opcional; sem isto matching usa fuzzy) ===
GEMINI_API_KEY=

# === NFC-e — Infosimples Sergipe (opcional; sem isto SE indisponível) ===
INFOSIMPLES_TOKEN=

# === Runtime ===
NODE_ENV=development
PORT=3010
